---
import Button from './Button.astro';
import Hero from './Hero.astro';
import GithubMark from '@/assets/github-mark.svg';
import LinkedinMark from '@/assets/linkedin-mark.svg';
import MailSvg from '@/assets/mail.svg';
import { welcomeTranslations } from '@/i18n/welcome.ts';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = welcomeTranslations[lang];
---

<div class="flex flex-col lg:flex-row items-center justify-center h-full">
    <div class="md:ml-4 lg:ml-8">
        <h2
            class="text-2xl md:text-4xl lg:text-5xl font-bold text-white motion-preset-slide-right motion-delay-[250ms] motion-duration-500"
        >
            {t.welcome}
        </h2>

        <h1
            class="motion-preset-slide-right py-1 md:py-4 motion-delay-[600ms] motion-duration-500 font-sans text-transparent uppercase bg-clip-text bg-gradient-to-br to-[#562b63] from-20% via-[#e082c9] via-60% from-[#f7d8e9] to-80% leading-normal text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold"
        >
            {t.name}
        </h1>

        <h2
            class="text-2xl md:text-4xl lg:text-5xl font-bold text-white mb-4 motion-preset-slide-right motion-delay-[1000ms] motion-duration-500"
        >
            <span id="typed-role" data-roles={JSON.stringify(t.roles)}></span>
        </h2>

        <div class="flex gap-2">
            <!--CV-->
            <a
                href={t.cvSrc}
                aria-label="Descargar CV"
                class="motion-preset-focus motion-delay-[1400ms] motion-duration-300"
                target="_blank"
                rel="noopener noreferrer"
            >
                <Button text={t.downloadCv} />
            </a>
            <!--Github-->
            <a
                class="hover:scale-95 rounded-full hover:shadow-lg hover:shadow-white/30 motion-preset-focus motion-delay-[1700ms] motion-duration-300 transform-gpu"
                href="https://github.com/Thesportydar"
                target="_blank"
            >
                <GithubMark class="size-10 md:size-12" fill="white" />
            </a>
            <!--Linkedin-->
            <a
                class="hover:scale-95 rounded-xl hover:shadow-lg hover:shadow-white/30 motion-preset-focus motion-delay-[2000ms] motion-duration-300 transform-gpu"
                href="https://www.linkedin.com/in/ipaladino/"
                target="_blank"
            >
                <LinkedinMark class="size-10 md:size-12" fill="white" />
            </a>
            <!--Mailto-->
            <a
                class="hover:scale-95 rounded-2xl hover:shadow-lg hover:shadow-white/30 motion-preset-focus motion-delay-[2300ms] motion-duration-300 transform-gpu"
                href="mailto:ipaladinobravo@gmail.com"
                aria-label="Enviar un mail"
                target="_blank"
            >
                <MailSvg class="size-10 md:size-12" fill="white" />
            </a>
        </div>
    </div>

    <div
        class="hidden lg:flex flex-1 h-full justify-center motion-preset-slide-left motion-delay-[250ms] motion-duration-500"
    >
        <Hero />
    </div>
</div>

<style>
    /* Override typed.js cursor to match the site's white text */
    .typed-cursor {
        color: white;
        font-weight: 300;
        opacity: 1;
        animation: typed-blink 0.7s infinite;
    }
    @keyframes typed-blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    import Typed from 'typed.js';

    const el = document.getElementById('typed-role');
    if (el) {
        const roles: string[] = JSON.parse(el.dataset.roles ?? '[]');
        new Typed('#typed-role', {
            strings: roles,
            typeSpeed: 55,
            backSpeed: 35,
            backDelay: 1500,
            startDelay: 1100,
            loop: true,
            smartBackspace: true,
            showCursor: true,
            cursorChar: '|',
        });
    }
</script>
